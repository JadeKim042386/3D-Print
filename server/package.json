{
  "name": "dpr-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "worker": "tsx --env-file=.env src/worker.ts",
    "dimension-worker": "tsx --env-file=.env src/dimension-worker.ts",
    "print-readiness-worker": "tsx --env-file=.env src/print-readiness-worker.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@sentry/node": "^10.49.0",
    "@supabase/supabase-js": "^2.49.0",
    "@trpc/server": "^11.0.0",
    "bullmq": "^5.34.0",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.0",
    "nodemailer": "^8.0.5",
    "posthog-node": "^5.29.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
